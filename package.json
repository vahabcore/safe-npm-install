{
    "name": "safe-npm-install",
    "version": "1.0.0",
    "description": "Pre-install risk analysis for npm packages. Scores and blocks suspicious packages before they reach your node_modules.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "safe-install": "dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc && node scripts/postbuild.mjs",
        "dev": "tsc --watch",
        "lint": "eslint src/ tests/",
        "lint:fix": "eslint src/ tests/ --fix",
        "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "npm",
        "security",
        "cli",
        "supply-chain",
        "audit",
        "risk",
        "safe-install"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/node": "^20.11.0",
        "eslint": "^9.0.0",
        "prettier": "^3.2.0",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.0.0",
        "vitest": "^1.2.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
